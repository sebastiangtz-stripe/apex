# ── Identity ──────────────────────────────────────────────────────────────────
# Your outbound email identities (comma-separated, case-insensitive substring match).
# Used by scan/review to detect emails YOU sent vs received. Include every alias /
# shared inbox you send merchant communications from.
MY_OUTBOUND_ADDRESSES=your.name@stripe.com,accelerate@stripe.com

# ── Asana ─────────────────────────────────────────────────────────────────────
# Generate a Personal Access Token at https://app.asana.com/0/my-apps
ASANA_PAT=REPLACE_WITH_YOUR_ASANA_PAT
ASANA_WORKSPACE_GID=REPLACE_WITH_WORKSPACE_GID

# Main project board (one task per merchant)
ASANA_PROJECT_GID=REPLACE
ASANA_SECTION_RECEIVED=REPLACE
ASANA_SECTION_GREEN=REPLACE
ASANA_SECTION_YELLOW=REPLACE
ASANA_SECTION_COMPLETED=REPLACE
ASANA_SECTION_TERMINATED=REPLACE

# Action Items cross-project (unified task view across all merchants)
ASANA_AI_PROJECT_GID=REPLACE
ASANA_AI_SECTION_TODAY=REPLACE
ASANA_AI_SECTION_THIS_WEEK=REPLACE
ASANA_AI_SECTION_LATER=REPLACE
ASANA_AI_SECTION_WAITING=REPLACE
ASANA_AI_FIELD_MERCHANT=REPLACE
ASANA_AI_FIELD_TAG=REPLACE
ASANA_AI_TAG_EMAIL=REPLACE
ASANA_AI_TAG_REPLY=REPLACE
ASANA_AI_TAG_RESEARCH=REPLACE
ASANA_AI_TAG_PREP=REPLACE
ASANA_AI_TAG_SCHEDULE=REPLACE
ASANA_AI_TAG_TRACK=REPLACE
ASANA_AI_TAG_LOG=REPLACE
ASANA_AI_TAG_WAITING=REPLACE
ASANA_AI_FIELD_COMPLEXITY=REPLACE
ASANA_AI_COMPLEXITY_LOW=REPLACE
ASANA_AI_COMPLEXITY_MEDIUM=REPLACE
ASANA_AI_COMPLEXITY_HIGH=REPLACE

# Main board custom fields (all auto-discovered by setup-discover-asana.py)
ASANA_FIELD_ACTIVE=REPLACE
ASANA_FIELD_ACTIVE_YES=REPLACE
ASANA_FIELD_ACTIVE_NO=REPLACE
ASANA_FIELD_ONR=REPLACE
ASANA_FIELD_PRODUCTS=REPLACE
ASANA_FIELD_PRODUCT_PAYMENTS=REPLACE
ASANA_FIELD_PRODUCT_BILLING=REPLACE
ASANA_FIELD_PRODUCT_RADAR=REPLACE
ASANA_FIELD_PRODUCT_TERMINAL=REPLACE
ASANA_FIELD_PRODUCT_CONNECT=REPLACE
ASANA_FIELD_PRODUCT_INVOICING=REPLACE
ASANA_FIELD_PRODUCT_TAX=REPLACE
ASANA_FIELD_PRODUCT_SIGMA=REPLACE
ASANA_FIELD_PRODUCT_IDENTITY=REPLACE
ASANA_FIELD_ACCOUNT_EXEC=REPLACE
ASANA_FIELD_ACTIVATION_QUARTER=REPLACE
ASANA_FIELD_QUARTER_Q2=REPLACE
ASANA_FIELD_QUARTER_Q3=REPLACE
ASANA_FIELD_QUARTER_Q4=REPLACE
ASANA_FIELD_GLD=REPLACE
ASANA_FIELD_IS_PLATFORM=REPLACE
ASANA_FIELD_PLATFORM_YES=REPLACE
ASANA_FIELD_PLATFORM_NO=REPLACE
ASANA_FIELD_STATUS=REPLACE
ASANA_FIELD_STATUS_GREEN=REPLACE
ASANA_FIELD_STATUS_YELLOW=REPLACE
ASANA_FIELD_STATUS_RED=REPLACE
ASANA_FIELD_STATUS_LIVE=REPLACE
ASANA_FIELD_STATUS_TERMINATED=REPLACE
ASANA_FIELD_STATUS_COMPLETED=REPLACE
ASANA_FIELD_ACCT_ID=REPLACE

# ── Slack handover detection ──────────────────────────────────────────────────
# AMER handover channel (#ven-ext-stripe-accelerate-amer). Hardcoded for all
# AMER consultants — no need to change this.
HANDOVER_CHANNEL_ID=C02HZETBG75
# Legacy channel preserved so historical handovers in #accelerate-qualification
# still resolve when reconciling state. Safe to leave as-is.
HANDOVER_CHANNEL_ID_LEGACY=C02HZETBG75
# Your Slack username (no leading @). Used to detect @-mentions in handover
# threads. The /setup skill will collect this for you.
SLACK_HANDLE=REPLACE

# ── Hubble (SFDC + Kantata source of truth) ───────────────────────────────────
# The hubble-analyst runs the predetermined saved query (stripe/c5619e62) via
# the run_hubble_query MCP tool. The query is NEVER modified — results are
# filtered locally by HUBBLE_LEAD_FILTER.
#
# The per-user filter is isolated in HUBBLE_LEAD_FILTER below — set it to your
# full name as it appears in project_lead_user_name. The hubble-analyst filters
# returned rows locally using a case-insensitive full-name substring match.
#
# If you don't have Hubble access, leave HUBBLE_LEAD_FILTER as-is and the
# hubble-analyst subagent will skip gracefully.
HUBBLE_SAVED_QUERY_ID=stripe/c5619e62
HUBBLE_LEAD_FILTER=Your Full Name
HUBBLE_SNAPSHOT_TTL_HOURS=24
